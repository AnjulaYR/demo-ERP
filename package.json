{
  "name": "demo-erp-micro-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Demo ERP system using Angular micro frontends, design systems, and design tokens.",
  "scripts": {
    "start": "ng serve shell",
    "start:shell": "ng serve shell --port 4200",
    "start:customers": "ng serve customers --port 4201",
    "start:inventory": "ng serve inventory --port 4202",
    "start:sales": "ng serve sales --port 4203",
    "start:finance": "ng serve finance --port 4204",
    "api:dev": "tsx watch apps/api/src/main.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:psql": "docker compose exec postgres psql -U demo_erp -d demo_erp",
    "build": "ng build",
    "build:all": "npm run build:shell && npm run build:customers && npm run build:inventory && npm run build:sales && npm run build:finance",
    "build:shell": "ng build shell",
    "build:customers": "ng build customers",
    "build:inventory": "ng build inventory",
    "build:sales": "ng build sales",
    "build:finance": "ng build finance",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular-architects/native-federation": "^20.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "es-module-shims": "^1.10.1",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jasmine": "^5.1.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "jasmine-core": "^5.7.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
